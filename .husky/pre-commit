#!/bin/sh
# ultracite — 仅对本次暂存的可 lint 文件做格式化/检查（lint-staged 风格）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|jsonc|css)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# 对暂存文件运行 ultracite（本地依赖），捕获退出码以便仍能重新暂存并报告
FORMAT_EXIT_CODE=0
echo "$STAGED_FILES" | xargs pnpm exec ultracite fix || FORMAT_EXIT_CODE=$?

# 重新暂存被格式化的文件
echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add -- "$file"
  fi
done

if [ "$FORMAT_EXIT_CODE" -ne 0 ]; then
  echo "Ultracite 在暂存文件中发现无法自动修复的问题。"
  exit "$FORMAT_EXIT_CODE"
fi

echo "✨ 已用 Ultracite 格式化暂存文件"
